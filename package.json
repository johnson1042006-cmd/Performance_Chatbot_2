{
  "name": "performance-chatbot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && playwright test --grep-invert @slow",
    "test:e2e:slow": "npm run build && playwright test --grep @slow",
    "test:e2e:all": "npm run build && playwright test",
    "test:catalog": "playwright test e2e/catalog-coverage.spec.ts",
    "dump:catalog": "tsx scripts/dump-catalog.ts",
    "catalog:refresh": "npx tsx scripts/refresh-catalog-skeleton.ts",
    "db:push": "npx drizzle-kit push",
    "db:seed": "npx tsx scripts/seed-users.ts",
    "db:retag-test": "npx tsx scripts/retag-test-sessions.ts",
    "db:rotate-passwords": "npx tsx scripts/rotate-prod-passwords.ts",
    "db:seed:knowledge": "npx tsx scripts/seed-knowledge.ts",
    "db:seed:products": "npx tsx scripts/seed-products.ts",
    "db:seed:catalog": "npx tsx scripts/seed-catalog.ts",
    "db:seed:colorways": "npx tsx scripts/seed-colorways.ts",
    "db:seed:pairings": "npx tsx scripts/seed-pairings.ts",
    "preflight": "npx tsx scripts/preflight.ts",
    "verify": "npm run lint && npm run test && npm run test:e2e",
    "sync:lightspeed": "npx tsx scripts/sync-lightspeed-pairings.ts",
    "sync-knowledge": "npx tsx scripts/sync-knowledge.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@auth/drizzle-adapter": "^1.11.1",
    "@neondatabase/serverless": "^1.0.2",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.577.0",
    "next": "14.2.35",
    "next-auth": "^4.24.13",
    "pusher": "^5.3.3",
    "pusher-js": "^8.4.3",
    "react": "^18",
    "react-dom": "^18",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.12.3",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5",
    "zod": "^4.1.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "jsdom": "^29.1.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
