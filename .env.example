# Anthropic API key — used by /api/chat and /api/chat/ai-fallback to call Claude.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Postgres connection string — Neon, Vercel Postgres, or any Postgres works.
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=

# Pusher Channels credentials — for real-time message delivery to dashboard and embed.
# Get them at https://dashboard.pusher.com/ (free tier is fine for low traffic).
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# Public Pusher values — exposed to the browser. Same key/cluster as above.
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# NextAuth.js — for dashboard manager/agent authentication.
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=
# In production, set this to your actual deployment URL (no trailing slash).
NEXTAUTH_URL=http://localhost:3000
# Local only: `npm run preflight` rejects localhost NEXTAUTH_URL unless this is 1.
# Never set in production.
# PREFLIGHT_ALLOW_LOCALHOST_NEXTAUTH=1

# Phase 3 — gates whether the AI model receives the tool catalog
# (search_products, lookup_order, escalate_to_human, etc.). MUST be
# "true" in production. Without it the bot has no catalog access and
# will hallucinate every product question.
USE_AI_TOOLS=true

# Phase 2b — Sonnet routing/classification layer. When "true", the FIRST
# AI turn of each conversation is classified by Sonnet (category + missing
# fitment fields) and a routing directive is injected into the system
# prompt. Haiku still writes every customer-facing reply. Low-confidence
# or errored classifications fall back to the plain Haiku path silently.
USE_ROUTING_CLASSIFIER=false
# Optional model override for the classifier (default claude-sonnet-5).
# ROUTING_CLASSIFIER_MODEL=claude-sonnet-5

# BigCommerce Storefront API — required for live product lookups.
# Store hash from your BC URL: https://store-{HASH}.mybigcommerce.com
# Access token from BC admin: Settings → API → API Accounts.
BIGCOMMERCE_STORE_HASH=
BIGCOMMERCE_ACCESS_TOKEN=

# Cron job secret — used to authenticate scheduled jobs (/api/cron/*).
# Generate with: openssl rand -base64 32
# Vercel Cron auto-includes this in scheduled requests once set as an env var.
CRON_SECRET=

# Lightspeed Retail (optional — for auto-populating product pairings).
# Leave blank if not using Lightspeed.
LIGHTSPEED_ACCOUNT_ID=
LIGHTSPEED_API_KEY=

# Phase 6 — Tech-Air service request inbox. The Tech-Air request form emails
# this address and also includes the customer's email for receipt.
SERVICE_INBOX=

# Resend (email delivery). Used by lib/email/sender.ts and transcript flows.
RESEND_API_KEY=
# Optional: override default From.
RESEND_FROM_EMAIL=
# Phase 3/5.5 — support callback inbox (offline human requests).
SUPPORT_INBOX=
